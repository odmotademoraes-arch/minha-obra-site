{
  "name": "minha-obra",
  "version": "1.0.0",
  "description": "Sistema de Gestão de Obras para Engenheiros Civis",
  "main": "main.js",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && node scripts/launch-electron.js\"",
    "build": "vite build",
    "make-icons": "node scripts/make-icons.js",
    "electron:build": "node scripts/make-icons.js && vite build && electron-builder"
  },
  "build": {
    "appId": "com.minhaobra.app",
    "productName": "Minha Obra",
    "asar": true,
    "asarUnpack": [
      "**/better_sqlite3.node",
      "**/node_modules/better-sqlite3/**"
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "scripts/**",
      "main/**",
      "dist/**",
      "node_modules/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/@electron/**",
      "!**/*.md",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "devDependencies": {
    "@jimp/core": "^1.6.1",
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^28.3.3",
    "electron-builder": "^24.9.1",
    "jimp": "^1.6.1",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.4.5",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@supabase/supabase-js": "^2.45.0",
    "better-sqlite3": "^9.4.3",
    "date-fns": "^3.6.0",
    "jspdf": "^2.5.1",
    "lucide-react": "^0.453.0",
    "pdfkit": "^0.18.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-is": "^18.3.0",
    "react-router-dom": "^6.27.0",
    "recharts": "^2.13.3",
    "xlsx": "^0.18.5"
  }
}
